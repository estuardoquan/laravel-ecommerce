{
    "name": "estuardoquan/laravel-ecommerce",
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "laravel/octane": "^2.17",
        "inertiajs/inertia-laravel": "^3.1",
        "laravel/passport": "^13.7"
    },
    "autoload": {
        "psr-4": {
            "EQ\\LaravelEcommerce\\": "src/"
        }
    },
	"autoload-dev": {
		"psr-4": {
			"EQ\\LaravelEcommerce\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"EQ\\LaravelEcommerce\\EcommerceServiceProvider"
			],
			"aliases": {}
		}
	},
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
